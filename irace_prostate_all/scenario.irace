## irace scenario — competencia ILS vs rVNS en PROSTATE_sampled K=4
## Cada run OSQP ≈ 30s; first-improvement con inner_iter=1..3, outer=1..3
## → run mínimo ~120s, máximo ~750s (timeout).
## Budget 20000s CPU / 4 cores ≈ 1.5h de pared.

execDir               = "/Users/marrojasr/Documents/code/emili_imrt"
parameterFile         = "/Users/marrojasr/Documents/code/emili_imrt/irace_prostate_all/parameters_prostate_all.irace"
logFile               = "/Users/marrojasr/Documents/code/emili_imrt/irace_prostate_all/results/irace.log"
trainInstancesFile    = "/Users/marrojasr/Documents/code/emili_imrt/irace_prostate_all/instances.txt"
targetRunner          = "/Users/marrojasr/Documents/code/emili_imrt/irace_prostate_all/target-runner"

maxTime               = 20000
budgetEstimation      = 0.05
targetRunnerTimeout   = 600
parallel              = 4
seed                  = 42
deterministic         = FALSE

elitist               = TRUE
elitistNewInstances   = 1
elitistLimit          = 2
firstTest             = 5
