#!/usr/bin/env bash
# =============================================================================
# target-runner — IRACE wrapper for BAO + VNS (PROSTATE real, K=4)
#
# Tuneable parameters:
#   --inner_explore  {first,best}       inner local search strategy
#   --inner_init     {ifirstk,irandomk} BAO initial solution
#   --inner_iter     {1..3}             inner LS max iterations
#   --outer_iter     {1..5}             VNS outer loop iterations
#   --p_max          {1..5}             shake max strength
#   --w_under        [1..1000]          PTV underdose penalty
#   --w_over         [0.01..10]         OAR overdose penalty
#   --w_ptv_over     [0.1..50]          PTV hotspot penalty
# =============================================================================
set -euo pipefail

EMILI="${EMILI:-$(cd "$(dirname "$0")/.." && pwd)/build/emili}"

CONFIG_ID=$1; shift
INSTANCE_ID=$1; shift
SEED=$1; shift
INSTANCE=$1; shift

# Defaults (baseline from benchmark)
inner_explore="best"
inner_init="ifirstk"
inner_iter=1
outer_iter=2
p_max=2
w_under=1.0
w_over=0.5
w_ptv_over=0.5

while [[ $# -gt 0 ]]; do
    case "$1" in
        --inner_explore) inner_explore="$2"; shift 2 ;;
        --inner_init)    inner_init="$2";    shift 2 ;;
        --inner_iter)    inner_iter="$2";    shift 2 ;;
        --outer_iter)    outer_iter="$2";    shift 2 ;;
        --p_max)         p_max="$2";         shift 2 ;;
        --w_under)       w_under="$2";       shift 2 ;;
        --w_over)        w_over="$2";        shift 2 ;;
        --w_ptv_over)    w_ptv_over="$2";    shift 2 ;;
        *) shift ;;
    esac
done

# K=4 hardcoded for prostate
K=4

# ── Temp instance with tuned weights ───────────────────────────────────────
TEMP_INST=$(mktemp -d)
cleanup() { rm -rf "$TEMP_INST"; }
trap 'cleanup; ELAPSED=$(( $(date +%s) - START_TIME )); echo "1e30 $ELAPSED"; exit 0' TERM INT
trap 'cleanup' EXIT

for f in "$INSTANCE"/*; do
    fname=$(basename "$f")
    if [ "$fname" != "instance_config.txt" ]; then
        cp "$f" "$TEMP_INST/$fname"
    fi
done

cp "$INSTANCE/instance_config.txt" "$TEMP_INST/instance_config.txt"
sed -i "s/^w_under[[:space:]].*/w_under       $w_under/"     "$TEMP_INST/instance_config.txt"
sed -i "s/^w_over[[:space:]].*/w_over        $w_over/"       "$TEMP_INST/instance_config.txt"
sed -i "s/^w_ptv_over[[:space:]].*/w_ptv_over    $w_ptv_over/"   "$TEMP_INST/instance_config.txt"

START_TIME=$(date +%s)
STDERR_LOG="$TEMP_INST/emili_stderr.log"

OUTPUT=$("$EMILI" "$TEMP_INST" baoimrt "$K" \
    vns "$inner_explore" "$inner_init" tmaxiter "$inner_iter" nangswap \
    tmaxiter "$outer_iter" bangshake "$p_max" accng improve \
    rnds "$SEED" 2>"$STDERR_LOG") || true

END_TIME=$(date +%s)
ELAPSED=$(( END_TIME - START_TIME ))

RESULT=$(echo "$OUTPUT" | grep "Objective function value:" | tail -1 | awk '{print $NF}')

if [[ -z "$RESULT" ]]; then
    echo "1e30 $ELAPSED"
else
    echo "$RESULT $ELAPSED"
fi
