<?xml version="1.0" encoding="UTF-8" ?>

<!-- IMRT grammar — búsqueda local, ILS, Tabu y VNS para irace/GGA
     Problema: imrt (minúsculas, coincide con ImrtBuilder::isCompatibleWith)
     Builders activos en main.cpp:
       EmBaseBuilder  → estructura de algoritmos (first, best, ils, tabu, vns, vnd, nols…)
       ImrtBuilder    → componentes IMRT-específicos (izero, iuniform, irandom, nshift, nswap,
                        prandom, aimprove, tmaxiter, tfeasible)
-->

<gr:grammar xmlns:gr="grammar">
    <gr:derivations xmlns:imrt="imrt_automatic_generation">

        <!-- ── Parámetros numéricos IMRT ──────────────────────────────────── -->
        <imrt:delta         type="real" min="0.1"    max="5.0"     stepIfEnumerated="0.1"/>
        <imrt:intensity     type="real" min="0.5"    max="10.0"    stepIfEnumerated="0.5"/>
        <imrt:max_intensity type="real" min="1.0"    max="10.0"    stepIfEnumerated="1.0"/>

        <!-- ── Parámetros generales de metaheurísticas ────────────────────── -->
        <imrt:metrotemp       type="real" min="0.1"    max="300"     stepIfEnumerated="1"/>
        <imrt:tabutenure_size type="int"  min="1"      max="200"     stepIfEnumerated="1"/>
        <imrt:random_moves    type="int"  min="1"      max="100"     stepIfEnumerated="1"/>
        <imrt:start_temp      type="real" min="1.1"    max="50000.0" stepIfEnumerated="0.0001"/>
        <imrt:end_temp        type="real" min="0"      max="1.0"     stepIfEnumerated="0.0001"/>
        <imrt:temp_ratio      type="real" min="0.0001" max="1"       stepIfEnumerated="0.0001"/>
        <imrt:tempiterations  type="int"  min="1"      max="5000"    stepIfEnumerated="1"/>
        <imrt:steps           type="int"  min="1000"   max="100000"  stepIfEnumerated="1000"/>

        <imrt:always_acc_param>
            <![CDATA[intensify ]]>
            <or/>
            <![CDATA[diversify ]]>
        </imrt:always_acc_param>

        <!-- accng: wrapping de aceptación para VNS -->
        <imrt:accng>
            <![CDATA[accng ]]>
            <imrt:acceptance/>
        </imrt:accng>

        <!-- pershake: secuencia de 3 perturbaciones para VNS -->
        <imrt:pershake>
            <![CDATA[pershake ]]>
            <imrt:pertubation/>
            <imrt:pertubation/>
            <imrt:pertubation/>
        </imrt:pershake>

        <!-- ── Solución inicial (ImrtBuilder) ─────────────────────────────── -->
        <imrt:initial_solution>
            <![CDATA[izero ]]>
            <or/>
            <![CDATA[iuniform ]]><imrt:intensity/><![CDATA[ ]]>
            <or/>
            <![CDATA[irandom ]]><imrt:max_intensity/><![CDATA[ ]]>
        </imrt:initial_solution>

        <!-- ── Criterio de terminación (EmBaseBuilder) ────────────────────── -->
        <imrt:termination>
            <![CDATA[locmin ]]>
            <or/>
            <![CDATA[true ]]>
            <or/>
            <![CDATA[maxstep ]]><imrt:steps/><![CDATA[ ]]>
            <or/>
            <![CDATA[eval ]]>
        </imrt:termination>

        <!-- ── Vecindarios (ImrtBuilder) ──────────────────────────────────── -->
        <imrt:neighborhood>
            <![CDATA[nshift ]]><imrt:delta/><![CDATA[ ]]>
            <or/>
            <![CDATA[nswap ]]>
        </imrt:neighborhood>

        <!-- ── Perturbación (EmBaseBuilder: rndmv, noper, secper) ─────────── -->
        <imrt:pertubation>
            <![CDATA[rndmv ]]><imrt:neighborhood/><![CDATA[ ]]><imrt:random_moves/><![CDATA[ ]]>
            <or/>
            <![CDATA[noper ]]>
            <or/>
            <![CDATA[secper ]]>
            <![CDATA[rndmv ]]><imrt:neighborhood/><![CDATA[ ]]><imrt:random_moves/><![CDATA[ ]]>
            <![CDATA[rndmv ]]><imrt:neighborhood/><![CDATA[ ]]><imrt:random_moves/><![CDATA[ ]]>
            <![CDATA[rndmv ]]><imrt:neighborhood/><![CDATA[ ]]><imrt:random_moves/><![CDATA[ ]]>
        </imrt:pertubation>

        <!-- ── Criterio de aceptación (EmBaseBuilder) ─────────────────────── -->
        <imrt:acceptance>
            <![CDATA[metropolis ]]><imrt:metrotemp/><![CDATA[ ]]>
            <or/>
            <![CDATA[improve ]]>
            <or/>
            <![CDATA[always ]]><imrt:always_acc_param/>
            <or/>
            <![CDATA[sa_metropolis ]]><imrt:start_temp/><![CDATA[ ]]><imrt:end_temp/><![CDATA[ ]]><imrt:temp_ratio/><![CDATA[ ]]>
            <or/>
            <![CDATA[pmetro ]]><imrt:start_temp/><![CDATA[ ]]><imrt:end_temp/><![CDATA[ ]]><imrt:temp_ratio/><![CDATA[ ]]><imrt:tempiterations/><![CDATA[ ]]>
        </imrt:acceptance>

        <!-- ── Lista tabú (EmBaseBuilder) ─────────────────────────────────── -->
        <imrt:tabutenure>
            <![CDATA[Tabu_all_solution ]]><imrt:tabutenure_size/><![CDATA[ ]]>
            <or/>
            <![CDATA[Tabu_1_car ]]><imrt:tabutenure_size/><![CDATA[ ]]>
            <or/>
            <![CDATA[Tabu_1_position ]]><imrt:tabutenure_size/><![CDATA[ ]]>
        </imrt:tabutenure>

        <!-- ── Algoritmos base ─────────────────────────────────────────────── -->

        <imrt:first>
            <![CDATA[first ]]>
            <imrt:initial_solution/>
            <imrt:termination/>
            <imrt:neighborhood/>
        </imrt:first>

        <imrt:best>
            <![CDATA[best ]]>
            <imrt:initial_solution/>
            <imrt:termination/>
            <imrt:neighborhood/>
        </imrt:best>

        <imrt:firstvns>
            <![CDATA[first ]]>
            <imrt:initial_solution/>
            <imrt:termination/>
            <imrt:neighborhood/>
        </imrt:firstvns>

        <imrt:bestvns>
            <![CDATA[best ]]>
            <imrt:initial_solution/>
            <imrt:termination/>
            <imrt:neighborhood/>
            <imrt:neighborhood/>
            <imrt:neighborhood/>
        </imrt:bestvns>

        <imrt:ils>
            <![CDATA[ils ]]>
            <imrt:algos2/>
            <imrt:termination/>
            <imrt:pertubation/>
            <imrt:acceptance/>
        </imrt:ils>

        <imrt:tabu>
            <![CDATA[tabu ]]>
            <imrt:vnds/>
            <imrt:initial_solution/>
            <imrt:termination/>
            <imrt:neighborhood/>
            <imrt:tabutenure/>
        </imrt:tabu>

        <imrt:vnd>
            <![CDATA[vnd ]]>
            <imrt:vnds/>
            <imrt:initial_solution/>
            <imrt:termination/>
            <imrt:neighborhood/>
            <imrt:neighborhood/>
            <imrt:neighborhood/>
        </imrt:vnd>

        <!-- first/best dentro del vecindario en VND/VNS -->
        <imrt:vnds>
            <![CDATA[first ]]>
            <or/>
            <![CDATA[best ]]>
        </imrt:vnds>

        <imrt:vnds2>
            <imrt:firstvns/>
            <or/>
            <imrt:bestvns/>
        </imrt:vnds2>

        <imrt:vns>
            <![CDATA[vns ]]>
            <imrt:vnds2/>
            <imrt:termination/>
            <imrt:pershake/>
            <imrt:accng/>
        </imrt:vns>

        <imrt:nols>
            <![CDATA[nols ]]>
            <imrt:initial_solution/>
        </imrt:nols>

        <!-- Sub-algoritmo reutilizable como LS interno -->
        <imrt:algos2>
            <imrt:first/>
            <or/>
            <imrt:best/>
            <or/>
            <imrt:ils/>
            <or/>
            <imrt:tabu/>
            <or/>
            <imrt:vnd/>
            <or/>
            <imrt:nols/>
            <or/>
            <imrt:vns/>
        </imrt:algos2>

        <!-- Algoritmos principales expuestos al configurador -->
        <imrt:algos>
            <imrt:first/>
            <or/>
            <imrt:best/>
            <or/>
            <imrt:ils/>
            <or/>
            <imrt:tabu/>
            <or/>
            <imrt:vns/>
        </imrt:algos>

        <imrt:main>
            <imrt:algos/>
        </imrt:main>

        <imrt:main_algorithm output="params">
            <![CDATA[imrt ]]>
            <imrt:main/>
        </imrt:main_algorithm>

    </gr:derivations>
</gr:grammar>
