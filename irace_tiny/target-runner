#!/usr/bin/env bash
# target-runner para prueba TINY — BAO con K extraído del nombre de la instancia
#
# Parámetros tuneables vía IRACE:
#   --inner_explore {best,first}
#   --inner_init    {ifirstk,irandomk}
#   --inner_iter    {1,2}
#   --pert_swaps    {1,2}
#   --outer_iter    {1,2}
#   --outer_accept  {improve}
#   --w_under       [1..1000]
#   --w_over        [0.01..10]
#   --w_ptv_over    [0.1..50]
set -euo pipefail

EMILI="$(cd "$(dirname "$0")/.." && pwd)/build/emili"

CONFIG_ID=$1; shift
INSTANCE_ID=$1; shift
SEED=$1; shift
INSTANCE=$1; shift
BOUND=$1; shift

inner_explore="best"
inner_init="irandomk"
inner_iter=1
pert_swaps=1
outer_iter=1
outer_accept="improve"
w_under=1.0
w_over=0.5
w_ptv_over=0.5

while [[ $# -gt 0 ]]; do
    case "$1" in
        --inner_explore) inner_explore="$2"; shift 2 ;;
        --inner_init)    inner_init="$2";    shift 2 ;;
        --inner_iter)    inner_iter="$2";    shift 2 ;;
        --pert_swaps)    pert_swaps="$2";    shift 2 ;;
        --outer_iter)    outer_iter="$2";    shift 2 ;;
        --outer_accept)  outer_accept="$2";  shift 2 ;;
        --w_under)       w_under="$2";       shift 2 ;;
        --w_over)        w_over="$2";        shift 2 ;;
        --w_ptv_over)    w_ptv_over="$2";    shift 2 ;;
        *) shift ;;
    esac
done

BASENAME=$(basename "$INSTANCE")
K=$(echo "$BASENAME" | sed 's/.*_K//')
[[ "$K" =~ ^[0-9]+$ ]] || K=2

# ── Crear instancia temporal con pesos tuneados ──
TEMP_INST=$(mktemp -d)
cleanup() { rm -rf "$TEMP_INST"; }
trap 'cleanup; ELAPSED=$(python3 -c "import time; print(max(0.001, time.time() - $START_TIME))"); echo "1e30 $ELAPSED"; exit 0' TERM INT
trap 'cleanup' EXIT

for f in "$INSTANCE"/*; do
    fname=$(basename "$f")
    if [ "$fname" != "instance_config.txt" ]; then
        ln -s "$f" "$TEMP_INST/$fname"
    fi
done

cp "$INSTANCE/instance_config.txt" "$TEMP_INST/instance_config.txt"
sed -i '' "s/^w_under[[:space:]].*/w_under       $w_under/"     "$TEMP_INST/instance_config.txt"
sed -i '' "s/^w_over[[:space:]].*/w_over        $w_over/"       "$TEMP_INST/instance_config.txt"
sed -i '' "s/^w_ptv_over[[:space:]].*/w_ptv_over    $w_ptv_over/"   "$TEMP_INST/instance_config.txt"

START_TIME=$(python3 -c "import time; print(time.time())")

OUTPUT=$("$EMILI" "$TEMP_INST" baoimrt "$K" \
    ils "$inner_explore" "$inner_init" tmaxiter "$inner_iter" nangswap \
    tmaxiter "$outer_iter" prangswap "$pert_swaps" "$outer_accept" \
    2>/dev/null) || true

ELAPSED=$(python3 -c "import time; print(max(0.001, time.time() - $START_TIME))")

RESULT=$(echo "$OUTPUT" | grep "Objective function value:" | awk '{print $NF}')

if [[ -z "$RESULT" ]]; then
    echo "1e30 $ELAPSED"
else
    echo "$RESULT $ELAPSED"
fi
